# Required: Supabase for magic-link sign-in and synced analysis history.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: rolling per-IP limit for POST /api/analyze (default 24 per minute).
RATE_LIMIT_AI_PER_MINUTE=24

# Required in production: secret used to encrypt short-lived API key cookies.
# Generate a long random value and keep it private.
CONFIG_ENCRYPTION_KEY=
